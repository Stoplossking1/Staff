# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4.1-mini

# Laminar observability
LMNR_PROJECT_API_KEY=lmnr_your_project_api_key
LMNR_BASE_URL=https://api.lmnr.ai
LMNR_ENV=local

# Browser Use MCP (set one mode)
# local: run MCP server locally via uvx
# remote: connect to an existing MCP SSE endpoint
BROWSER_USE_MCP_MODE=local
BROWSER_USE_MCP_COMMAND=uvx
BROWSER_USE_MCP_ARGS='browser-use[cli] --mcp'
BROWSER_USE_MCP_URL=

# Local run wiring
STREAM_PORT=5173
STREAM_URL=http://127.0.0.1:5173

# Agent loop entrypoint (edit for your implementation)
AGENT_LOOP_CMD='python -m agent.loop'

# Convex real-time database
CONVEX_URL=https://your-deployment.convex.cloud
