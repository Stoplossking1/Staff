{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/contracts/race_state.schema.json",
  "title": "RaceState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "tick_ts_utc",
    "lap",
    "flag_status",
    "weather",
    "active_events"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Contract schema version. Current: 1.0.0."
    },
    "session_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique replay/session identifier shared across services."
    },
    "tick_ts_utc": {
      "type": "string",
      "format": "date-time",
      "description": "Wall-clock timestamp for this state snapshot in UTC."
    },
    "lap": {
      "type": "integer",
      "minimum": 0
    },
    "flag_status": {
      "type": "string",
      "enum": [
        "GREEN",
        "YELLOW",
        "DOUBLE_YELLOW",
        "RED",
        "SAFETY_CAR",
        "VSC",
        "CHEQUERED"
      ]
    },
    "weather": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "condition",
        "track_temp_c",
        "air_temp_c",
        "precipitation_pct",
        "wind_kph"
      ],
      "properties": {
        "condition": {
          "type": "string",
          "enum": [
            "CLEAR",
            "CLOUDY",
            "LIGHT_RAIN",
            "HEAVY_RAIN",
            "MIXED"
          ]
        },
        "track_temp_c": {
          "type": "number"
        },
        "air_temp_c": {
          "type": "number"
        },
        "precipitation_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "wind_kph": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "active_events": {
      "type": "array",
      "description": "Currently actionable events carried into decisioning.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "event_id",
          "event_type",
          "severity",
          "confidence",
          "timestamp_s"
        ],
        "properties": {
          "event_id": {
            "type": "string",
            "minLength": 1
          },
          "event_type": {
            "type": "string",
            "enum": [
              "OVERTAKE",
              "YELLOW_FLAG",
              "SAFETY_CAR",
              "VSC",
              "PIT_STOP",
              "CRASH",
              "SPIN",
              "TRACK_LIMITS",
              "WEATHER_SHIFT",
              "RETIREMENT",
              "FASTEST_LAP"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "INFO",
              "LOW",
              "MEDIUM",
              "HIGH",
              "CRITICAL"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "timestamp_s": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    }
  },
  "examples": [
    {
      "schema_version": "1.0.0",
      "session_id": "australia_gp_replay_2026_qf",
      "tick_ts_utc": "2026-03-01T17:22:13Z",
      "lap": 23,
      "flag_status": "YELLOW",
      "weather": {
        "condition": "CLOUDY",
        "track_temp_c": 33.2,
        "air_temp_c": 24.1,
        "precipitation_pct": 10,
        "wind_kph": 15.4
      },
      "active_events": [
        {
          "event_id": "evt_20260301_00125",
          "event_type": "YELLOW_FLAG",
          "severity": "MEDIUM",
          "confidence": 0.92,
          "timestamp_s": 412.34
        }
      ]
    }
  ]
}
